{
  "name": "findable-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --format esm",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "bun x drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun src/db/migrate.ts",
    "db:seed": "bun src/db/seed.ts",
    "shopify:dev": "shopify app dev",
    "shopify:deploy": "shopify app deploy"
  },
  "dependencies": {
    "@findable/shared": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "bullmq": "^5.50.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0",
    "ioredis": "^5.5.0",
    "jose": "^6.2.2",
    "openai": "^6.33.0",
    "pg": "^8.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@shopify/cli": "^3.0.0",
    "@types/pg": "^8.15.0",
    "bun-types": "^1.3.11",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.0"
  }
}
