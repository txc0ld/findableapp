{% comment %}
  FindAble Schema Injection Block

  Adds to any product page via the theme editor.
  Fetches pre-generated JSON-LD from FindAble API and injects into the page.

  The block is invisible — no UI rendered. Only schema in <head>.

  Merchant adds this via:
  Theme Editor → Product Page → Add Block → FindAble JSON-LD

  Also supports collection pages when added there.
{% endcomment %}

{% if product %}
  <script
    id="findable-schema-loader"
    src="{{ 'findable-loader.js' | asset_url }}"
    data-product-id="{{ product.id }}"
    data-product-handle="{{ product.handle }}"
    data-product-url="{{ product.url | prepend: shop.url }}"
    data-shop="{{ shop.permanent_domain }}"
    defer
  ></script>

  {% comment %}
    Remove any duplicate Product schema injected by the theme.
    FindAble's server-generated schema is more complete and correct.
    Uncomment the block below if merchants report duplicate schema warnings.
  {% endcomment %}
  {% comment %}
  <script data-findable="cleanup">
    (function() {
      var scripts = document.querySelectorAll('script[type="application/ld+json"]:not([data-findable])');
      for (var i = 0; i < scripts.length; i++) {
        try {
          var data = JSON.parse(scripts[i].textContent);
          if (data['@type'] === 'Product' || data['@type'] === 'ProductGroup') {
            scripts[i].parentNode.removeChild(scripts[i]);
          }
        } catch(e) {}
      }
    })();
  </script>
  {% endcomment %}
{% endif %}

{% schema %}
{
  "name": "FindAble JSON-LD",
  "target": "head",
  "stylesheet": false,
  "javascript": false,
  "settings": [],
  "presets": [
    {
      "name": "FindAble JSON-LD"
    }
  ]
}
{% endschema %}
